# ─── Server ───
BACKEND_PORT=3001

# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/renaiss_market

# ─── Renaiss API ───
RENAISS_API_URL=https://www.renaiss.xyz

# ─── Sync Auth (Basic Auth for /api/sync, /api/snkrdunk, /api/pricecharting, /api/combined) ───
DEBUG_USERNAME=admin
DEBUG_PASSWORD=

# ─── MiMo Vision API ───
MIMO_API_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5

# ─── Proxy (for Jina / external API calls) ───
HTTP_PROXY_RENAISS=

# ─── Cron Jobs ───
CRON_ENABLED=true
